pipeline {
    agent any

    stages {
        stage('Muhammad Bilal - Build') {
            steps {
                echo 'Starting Build Stage for Roll No: 22F-3723'
                bat 'npm run build'
            }
        }
        stage('Muhammad Bilal - Test') {
            steps {
                echo 'Starting Test Stage for Roll No: 22F-3723'
                bat 'npm run test'
            }
        }
        stage('Muhammad Bilal - Deploy') {
            when {
                expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
            }
            steps {
                echo '========================================'
                echo 'DEPLOY STAGE: Muhammad Bilal (22F-3723)'
                echo '========================================'
                echo 'Deploying application to Windows environment...'
                echo '✅ Deployment Finished Successfully!'
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline execution finished.'
        }
    }
}